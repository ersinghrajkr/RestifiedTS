{
  "name": "restifiedts",
  "version": "1.0.0",
  "description": "RestifiedTS is a powerful, lightweight, and fully extensible API automation framework built in TypeScript, designed as a battle-ready alternative to Java’s RestAssured — but with modern capabilities tailored for JavaScript/Node.js ecosystems.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "restifiedts": "dist/cli/index.js"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:watch": "tsc --watch",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "test": "mocha -r ts-node/register -r tsconfig-paths/register 'tests/**/*.test.ts'",
    "test:unit": "mocha -r ts-node/register -r tsconfig-paths/register 'tests/unit/**/*.test.ts'",
    "test:integration": "mocha -r ts-node/register -r tsconfig-paths/register 'tests/integration/**/*.test.ts'",
    "test:smoke": "mocha -r ts-node/register -r tsconfig-paths/register --grep '@smoke' 'tests/**/*.test.ts'",
    "test:regression": "mocha -r ts-node/register -r tsconfig-paths/register --grep '@regression' 'tests/**/*.test.ts'",
    "test:coverage": "nyc npm run test",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "docs:generate": "typedoc --out docs src/index.ts",
    "report:html": "mochawesome-merge reports/mochawesome-*.json | mochawesome-report-generator --inline",
    "cli": "node dist/cli/index.js",
    "generate-test": "node dist/cli/index.js generate",
    "mock-server": "json-server --watch tests/fixtures/mock-data.json --port 3001"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ersinghrajkr/RestifiedTS.git"
  },
  "keywords": [
    "Raj",
    "Kumar"
  ],
  "author": "Raj Kumar",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ersinghrajkr/RestifiedTS/issues"
  },
  "homepage": "https://github.com/ersinghrajkr/RestifiedTS#readme",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@graphql-tools/schema": "^10.0.23",
    "@types/axios": "^0.9.36",
    "@types/chai": "^5.2.2",
    "@types/express": "^5.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^10.0.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "axios": "^1.10.0",
    "bottleneck": "^2.19.5",
    "boxen": "^8.0.1",
    "chai": "^5.2.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "concurrently": "^9.2.0",
    "cosmiconfig": "^9.0.0",
    "cross-env": "^7.0.3",
    "csv-parse": "^6.0.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.31.0",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "joi": "^17.13.3",
    "json-server": "^1.0.0-beta.3",
    "lodash-es": "^4.17.21",
    "marked": "^16.0.0",
    "mocha": "^11.7.1",
    "msw": "^2.10.4",
    "mustache": "^4.2.0",
    "nanoid": "^5.1.5",
    "nock": "^14.0.5",
    "npm-run-all2": "^8.0.4",
    "open": "^10.1.2",
    "ora": "^8.2.0",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "p-timeout": "^6.1.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "strip-ansi": "^7.1.0",
    "table": "^6.9.0",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "undici": "^7.11.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.0",
    "yargs": "^18.0.0",
    "zod": "^4.0.5"
  }
}
